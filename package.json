{
  "name": "renewal-tracker",
  "version": "1.0.0",
  "description": "Track all your renewals - licenses, insurance, passports, subscriptions, and more",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build-client": "cd client && npm run build",
    "build": "npm run build-client",
    "install-client": "cd client && npm install",
    "setup": "npm install && npm run install-client && npm run build-client",
    "dev-full": "concurrently \"npm run dev\" \"cd client && npm run dev\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true
  }
}
